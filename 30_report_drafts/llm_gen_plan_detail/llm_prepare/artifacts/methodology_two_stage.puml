@startuml methodology_two_stage
skinparam monochrome true
skinparam packageStyle rect
skinparam defaultFontName Arial

start
:Входные данные;
partition "Этап I: Региональный ГИС-скрининг" {
    :Расчет факторов затопления;
    :Взвешивание факторов (МАИ);
    :Интегральная карта опасности;
    :Наложение фактора подверженности;
    :Выделение топ-5 критических зон;
}
partition "Этап II: Детальное моделирование" {
    :2D гидродинамическая симуляция (SWE);
    :Выделение локальных "горячих точек";
}
:Разработка адресных рекомендаций;
stop
@enduml
