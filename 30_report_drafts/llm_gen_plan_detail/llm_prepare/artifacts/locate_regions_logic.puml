@startuml
title Алгоритм Locate Regions (ArcGIS Pro)

start

partition "Ввод данных и параметров" {
    :Входной растр пригодности (Risk Index);
    :Задание ограничений:
    * Количество регионов (N)
    * Общая и индивидуальная площадь
    * Форма (круг, квадрат и др.)
    * Расстояние между регионами;
}

partition "Этап 1: Генерация кандидатов (PRG)" {
    :Выбор стратегии разрешения (Low/Med/High);
    if (Высокое разрешение?) then (Да)
        :Рост регионов из каждой ячейки;
    else (Нет)
        :Ресемплинг и выбор опорных точек;
    endif
    :Итеративный рост регионов (Region Growing);
    :Расчет Utility (среднее/сумма) и Shape (компактность);
}

partition "Этап 2: Пространственная оптимизация" {
    if (Количество регионов <= 8?) then (Да)
        :Комбинаторный поиск оптимального набора;
    else (Нет)
        :Последовательный (Sequential) выбор лучших;
    endif
}

:Выходной растр выделенных зон;

stop
@enduml
