@startuml
allow_mixing

' === Визуальные настройки ===
skinparam shadow false
skinparam defaultFontName "PtSans"
skinparam defaultFontSize 12
skinparam roundCorner 10
skinparam linetype ortho

skinparam arrow {
    Color SlateGray
    Thickness 2
    FontColor DimGray
}

skinparam package {
    BackgroundColor White
    BorderColor LightGray
    FontColor Gray
    FontStyle Bold
}

' === БАЗЫ ДАННЫХ (Sources) ===
skinparam database {
    BackgroundColor LightPink
    BorderColor HotPink
}

' === ПРОЦЕССЫ (Transform & Params) ===
skinparam rectangle<<Transform>> {
    BackgroundColor PeachPuff
    BorderColor SandyBrown
}

skinparam rectangle<<ArcPy>> {
    BackgroundColor Lavender
    BorderColor MediumPurple
}

skinparam rectangle<<Param>> {
    BackgroundColor LemonChiffon
    BorderColor Gold
}

' === РЕЗУЛЬТАТЫ (Load / Target) ===
skinparam rectangle<<Result>> {
    BackgroundColor LightGreen
    BorderColor MediumSeaGreen
}

skinparam rectangle<<Ref>> {
    BackgroundColor White
    BorderColor SlateGrey
    BorderStyle dashed
}

' === МАКРОСЫ ===
!define DB(id, label) database "label" as id
!define FILE(id, label) artifact "label" as id <<File>>
!define PARAM(id, label) rectangle "label" as id <<Param>>
!define TRANSFORM(id, label) rectangle "label" as id <<Transform>>
!define ARCPY(id, label) rectangle "label" as id <<ArcPy>>
!define RESULT(id, label) rectangle "label" as id <<Result>>
!define ZONE(id, label) package "label" as id
!define REF(id, label) rectangle "label" as id <<Ref>>

title Схема моделирования поверхностного стока

ZONE(inputs, "Входные данные") {
    DB(landuse, "<b>WorldCover</b>\n(Покрытия)") 
    DB(soil, "<b>HiHydroSoil</b>\n(Группы почв)")
    DB(xrain, "<b>Статистика XRain</b>\n(Кривые IDF осадков)")
    REF(rx5, "<b>Rx5Day</b>\n(Макс. за 5 суток, мм)")
    REF(rx1, "<b>Rx1Day</b>\n(Макс. суточные, мм)")
}

ZONE(modeling, "Моделирование стока") {
    ' SCS-CN Calculation
    ARCPY(scs_calc, "<b>Перекодировка в SCS-CN</b>\n(Номер кривой)")
    PARAM(cn_ref, "<b>Справочник перекодировки</b>\n(Покрытие+Гидрогруппа->CN)")
    RESULT(cn,"<b>SCS-CN</b>\n(Кривые стока)")
    
    ' Runoff Depth
    ARCPY(runoff_calc_5, "<b>Расчет стока с ячейки</b>\n(Методика SCS (TR-55))")
    RESULT(run_rx5,"<b>Сток Rx5Day</b>\n(Слой в метрах)")
    
    ' Rainfall Intensity
    TRANSFORM(idf_analyze, "<b>Визуальный анализ кривых IDF</b>\n(Поиск max интенсивного ливня)")
    PARAM(rain_param, "<b>Max интенсивный ливень</b>\n(Длительность, доля от Rx1Day)")
    ARCPY(rain_intens_calc, "<b>Расчет интенсивности стока ливня</b>")
    RESULT(rx,"<b>Ливень</b>\n(Интенсивность ливня, мм/сек)")
}

landuse --> scs_calc
soil --> scs_calc
cn_ref .> scs_calc
scs_calc --> cn

rx5 --> runoff_calc_5
cn --> runoff_calc_5
runoff_calc_5 --> run_rx5

xrain --> idf_analyze
idf_analyze --> rain_param
rain_param --> rain_intens_calc
cn --> rain_intens_calc
rx1 --> rain_intens_calc
rain_intens_calc --> rx

@enduml